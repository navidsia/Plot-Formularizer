<Window x:Class="Plot_Formularizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Plot Digitizer"
        Background="#1F1F1F"
        Height="850"
        Width="1400"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <SolidColorBrush x:Key="PanelBrush" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7A0C12"/>
        <SolidColorBrush x:Key="AccentBrush2" Color="#A0161E"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F2F2F2"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#BDBDBD"/>
        <SolidColorBrush x:Key="InputBrush" Color="#242424"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,6,6,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush2}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3A3A3A"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="RowBackground" Value="#242424"/>
            <Setter Property="AlternatingRowBackground" Value="#2C2C2C"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>

            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="#242424"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderBrush" Value="#3A3A3A"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

    </Window.Resources>

    <Grid Margin="12">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="1"
                Padding="16,14,18,14">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel>

                    <TextBlock Text="Plot Digitizer"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="TxtStatus"
                               Text="Enter values → Upload image → Finish Setup → Click points"
                               Margin="0,6,0,14"
                               Foreground="{StaticResource MutedTextBrush}"/>

                    <Button x:Name="BtnUpload"
                            Content="Upload Plot Image"
                            Click="BtnUpload_Click"/>

                    <Button x:Name="ExcelUpload"
                            Content="Upload Excel File" Click="ExcelUpload_Click"   Visibility="Collapsed"
                            />


                    <Button x:Name="BtnFinishSetup"
                            Content="Finish Setup"
                            IsEnabled="False"/>

                    <Border Height="1"
                            Background="{StaticResource BorderBrush2}"
                            Margin="0,14"/>

                    <TextBlock Text="Axis Values"
                               FontSize="15"
                               FontWeight="SemiBold"/>

                    <UniformGrid Columns="3" Margin="0,8,0,0">

                        <StackPanel Margin="0,0,4,0">
                            <Label Content="X1"/>
                            <TextBox x:Name="TxtX1"/>
                        </StackPanel>

                        <StackPanel Margin="4,0,4,0">
                            <Label Content="X2"/>
                            <TextBox x:Name="TxtX2"/>
                        </StackPanel>

                        <StackPanel Margin="4,0,0,0">
                            <Label Content="Log X axis"/>
                            <CheckBox x:Name="ChkLogX" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Margin="0,6,4,0">
                            <Label Content="Y1"/>
                            <TextBox x:Name="TxtY1"/>
                        </StackPanel>

                        <StackPanel Margin="4,6,4,0">
                            <Label Content="Y2"/>
                            <TextBox x:Name="TxtY2"/>
                        </StackPanel>

                        <StackPanel Margin="4,6,0,0">
                            <Label Content="Log Y axis"/>
                            <CheckBox x:Name="ChkLogY" VerticalAlignment="Center"/>
                        </StackPanel>

                    </UniformGrid>

                    <Border Height="1"
                            Background="{StaticResource BorderBrush2}"
                            Margin="0,14"/>

                    <!-- ================= MAGNIFIER ================= -->
                    <TextBlock Text="Magnifier"
                               FontSize="15"
                               FontWeight="SemiBold"/>

                    <Border Width="160"
                            Height="160"
                            Margin="0,8,0,0"
                            Background="#1A1A1A"
                            BorderBrush="#444"
                            BorderThickness="1"
                            CornerRadius="8"
                            HorizontalAlignment="Left">

                        <Grid ClipToBounds="True">

                            <Image x:Name="ImgMagnifier"
                                   Width="160"
                                   Height="160"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                            <Line X1="80" Y1="0" X2="80" Y2="160" Stroke="Red"/>
                            <Line X1="0" Y1="80" X2="160" Y2="80" Stroke="Red"/>

                        </Grid>

                    </Border>

                    <Border Height="1"
                            Background="{StaticResource BorderBrush2}"
                            Margin="0,14"/>

                    <TextBlock Text="Digitized Points"
                               FontSize="15"
                               FontWeight="SemiBold"/>

                    <DataGrid x:Name="PointsGrid"
                              Height="260"
                              Margin="0,8,0,0"
                              AutoGenerateColumns="False"
                              IsEnabled="False">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="70"/>

                            <DataGridTextColumn Header="XP" Binding="{Binding XP}" Width="70"/>

                            <DataGridTextColumn Header="YP" Binding="{Binding YP}" Width="70"/>

                            <DataGridTextColumn Header="X" Binding="{Binding X}" Width="70"/>

                            <DataGridTextColumn Header="Y" Binding="{Binding Y}" Width="70"/>
                        </DataGrid.Columns>

                    </DataGrid>

                    <Button x:Name="BtnUndo"
                            Content="Undo"
                            Style="{StaticResource SecondaryButton}"
                            IsEnabled="False"/>

                    <Button x:Name="BtnClearAll"
                            Content="Clear All"
                            Style="{StaticResource SecondaryButton}"
                            IsEnabled="False"/>

                    <Button x:Name="BtnDeletePoint"
                            Content="Delete Selected"
                            Style="{StaticResource SecondaryButton}"
                            IsEnabled="False"/>
                    
                    <StackPanel Margin="4,0,4,0">
                        <Label Content="Number of Points for Interpolation"/>
                        <TextBox x:Name="Txtinterpol" Text="1000"/>
                        
                    </StackPanel>
                    <Button x:Name="BtnInterpolate"
                            Content="Interpolate"
                            Style="{StaticResource SecondaryButton}"
                            IsEnabled="False" Click="BtnInterpolate_Click"/>

                </StackPanel>

            </ScrollViewer>

        </Border>

        <Border Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="1"
                Padding="10">

            <Grid>

                <StackPanel x:Name="PreviewPlaceholder"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <TextBlock Text="Plot Preview"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Upload image to begin digitizing."
                               Margin="0,10,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"/>

                </StackPanel>

                <ScrollViewer x:Name="ImageScrollViewer"
                              Visibility="Collapsed"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">

                    <Grid>

                        <Image x:Name="ImgPlot"
                               Stretch="None"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                        <Canvas x:Name="OverlayCanvas"
                                Background="Transparent"
                                MouseLeftButtonDown="Img_MouseDown"
                                MouseMove="Img_MouseMove"/>

                    </Grid>

                </ScrollViewer>

            </Grid>

        </Border>

    </Grid>

</Window>